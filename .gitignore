node_modules/
output/

# User runtime data (the pipeline is local-first; ship empty dirs via .gitkeep)
/data/*
!/data/.gitkeep
/reports/*
!/reports/.gitkeep
batch/tracker-additions/
plugins.local/
plugins.lock
.update-backup/
.update-dismissed

# User onboarding files (created at first run; ship the .example templates instead)
/idea.md
/config/product.yml
/modes/_profile.md
/modes/_custom.md
/competitors.yml
/.agents/product-marketing.md
/brand/
/proof-points.md

# Vendored skills (installed at init via scaffolder / `npx skills add`) — don't commit.
# Keep the repo's own skills (product-ops, product-creation) tracked.
/.agents/skills/*
!/.agents/skills/product-ops/
!/.agents/skills/product-creation/
# Per-CLI skill dirs are populated at init by ensureSkillEntrypoints — ship empty.
/.claude/skills/*
!/.claude/skills/.gitkeep
/.opencode/skills/*
!/.opencode/skills/.gitkeep
/.qwen/skills/*
!/.qwen/skills/.gitkeep
/.antigravitycli/skills/*
!/.antigravitycli/skills/.gitkeep
/.grok/skills/*
!/.grok/skills/.gitkeep

.env
.env.*
.DS_Store
*.log
